{
  "name": "@fjordcleanup/trash",
  "version": "0.0.0-development",
  "description": "Web application to view and report trash to Fjord CleanUP",
  "type": "module",
  "imports": {
    "#domain/*": {
      "import": "./domain/*"
    },
    "#event/*": {
      "import": "./event/*"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fjordcleanup/trash.git"
  },
  "bugs": {
    "url": "https://github.com/fjordcleanup/trash/issues"
  },
  "homepage": "https://trash.fjordcleanup.org",
  "author": "Markus Tacker <m@coderbyheart.com> | https://coderbyheart.com",
  "license": "MIT",
  "scripts": {
    "start": "vite",
    "build": "node --max_old_space_size=8192 ./node_modules/vite/bin/vite.js build --emptyOutDir",
    "prepare": "husky",
    "test": "node --no-warnings --experimental-transform-types --test \"!(node_modules|e2e-tests|integration-tests)/**/*.spec.ts\"",
    "test:watch": "node --no-warnings --experimental-transform-types --test --watch \"!(node_modules|e2e-tests|integration-tests)/**/*.spec.ts\"",
    "cdk:lambda:update": "node --no-warnings --experimental-transform-types ./cdk/cli/update-lambdas.ts",
    "test:e2e": "node --experimental-transform-types --no-warnings  --test e2e-tests/**/*.spec.ts",
    "test:integration": "node --experimental-transform-types --no-warnings  --test integration-tests/**/*.spec.ts"
  },
  "dependencies": {
    "@aws-crypto/sha256-js": "5.2.0",
    "@aws-sdk/credential-provider-cognito-identity": "3.864.0",
    "@aws-sdk/credential-providers": "3.864.0",
    "@aws-sdk/s3-request-presigner": "3.864.0",
    "@bifravst/from-env": "3.0.2",
    "@hello.nrfcloud.com/lambda-helpers": "3.5.4",
    "@middy/core": "6.4.1",
    "@middy/input-output-logger": "6.4.1",
    "@sinclair/typebox": "0.34.38",
    "@smithy/protocol-http": "5.1.3",
    "@smithy/signature-v4": "5.1.3",
    "@smithy/types": "4.3.2",
    "bootstrap": "5.3.7",
    "classnames": "2.5.1",
    "compare-versions": "6.1.1",
    "date-fns": "4.1.0",
    "lucide-preact": "0.539.0",
    "maplibre-gl": "5.6.2",
    "oidc-client-ts": "3.3.0",
    "preact": "10.27.0",
    "preact-router": "4.1.2",
    "proj4": "2.19.10",
    "ulidx": "2.4.1"
  },
  "devDependencies": {
    "@aws-sdk/client-cloudfront": "3.864.0",
    "@aws-sdk/client-cloudwatch-logs": "3.864.0",
    "@aws-sdk/client-cognito-identity-provider": "3.864.0",
    "@aws-sdk/client-dynamodb": "3.864.0",
    "@aws-sdk/client-s3": "3.864.0",
    "@aws-sdk/client-ses": "3.864.0",
    "@aws-sdk/client-sts": "3.864.0",
    "@aws-sdk/util-dynamodb": "3.864.0",
    "@babel/plugin-syntax-import-assertions": "7.27.1",
    "@bifravst/aws-cdk-lambda-helpers": "3.4.39",
    "@bifravst/ci": "2.1.1",
    "@bifravst/cloudformation-helpers": "9.1.1",
    "@bifravst/eslint-config-typescript": "6.4.3",
    "@bifravst/prettier-config": "1.1.12",
    "@commitlint/config-conventional": "19.8.1",
    "@preact/preset-vite": "2.10.2",
    "@types/aws-lambda": "8.10.152",
    "@types/node": "24.2.1",
    "aws-cdk-lib": "2.210.0",
    "cdk": "2.1024.0",
    "commitlint": "19.8.1",
    "glob": "11.0.3",
    "handlebars": "4.7.8",
    "husky": "9.1.7",
    "lint-staged": "16.1.5",
    "typescript": "5.9.2",
    "vite": "7.1.1"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint"
    ],
    "*.{md,json,yaml,yml,html,css}": [
      "prettier --write"
    ]
  },
  "prettier": "@bifravst/prettier-config",
  "release": {
    "branches": [
      "saga"
    ],
    "remoteTags": true,
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      [
        "@semantic-release/github",
        {
          "successCommentCondition": false,
          "failTitle": false
        }
      ]
    ]
  }
}
