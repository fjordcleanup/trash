{
  "name": "@fjordcleanup/trash",
  "version": "0.0.0-development",
  "description": "Web application to view and report trash to Fjord CleanUP",
  "type": "module",
  "imports": {
    "#domain/*": {
      "import": "./domain/*"
    },
    "#error/*": {
      "import": "./error/*"
    },
    "#event/*": {
      "import": "./event/*"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fjordcleanup/trash.git"
  },
  "webAppRepository": {
    "type": "git",
    "url": "git+https://github.com/fjordcleanup/trash-web.git"
  },
  "bugs": {
    "url": "https://github.com/fjordcleanup/trash/issues"
  },
  "homepage": "https://trash.fjordcleanup.org",
  "author": "Markus Tacker <m@coderbyheart.com> | https://coderbyheart.com",
  "license": "MIT",
  "scripts": {
    "prepare": "husky && check-node-version --package",
    "test": "node --no-warnings --experimental-transform-types --test \"!(node_modules)/**/*.spec.ts\"",
    "test:watch": "node --no-warnings --experimental-transform-types --test --watch \"!(node_modules)/**/*.spec.ts\"",
    "cdk:lambda:update": "node --no-warnings --experimental-transform-types ./cdk/cli/update-lambdas.ts",
    "cdk:bootstrap": "node --experimental-transform-types --no-warnings ./cdk/bootstrap.ts",
    "cdk:ci:deploy": "node --experimental-transform-types --no-warnings ./cdk/test.ts",
    "cdk:ci:destroy": "node --experimental-transform-types --no-warnings ./cdk/test.ts --destroy",
    "cdk:prod:deploy": "node --experimental-transform-types --no-warnings ./cdk/prod.ts",
    "cdk:prod:diff": "node --experimental-transform-types --no-warnings ./cdk/prod.ts --diff",
    "cdk:prod:list": "node --experimental-transform-types --no-warnings ./cdk/prod.ts --list",
    "test:e2e": "node --experimental-transform-types --no-warnings ./features/run-features.ts > e2e-test-result.json && cat e2e-test-result.json | node --experimental-transform-types --no-warnings ./features/console-reporter.ts --only-failed --with-timestamps"
  },
  "dependencies": {
    "@aws-crypto/sha256-js": "5.2.0",
    "@aws-sdk/credential-provider-cognito-identity": "3.908.0",
    "@aws-sdk/credential-providers": "3.908.0",
    "@aws-sdk/s3-request-presigner": "3.908.0",
    "@bifravst/from-env": "3.0.2",
    "@coderbyheart/aws-dynamodb-es-cqrs": "1.3.0",
    "@fjordcleanup/trash-proto": "npm:@jsr/fjordcleanup__trash-proto@1.1.4",
    "@hello.nrfcloud.com/lambda-helpers": "3.5.21",
    "@middy/core": "6.4.5",
    "@middy/input-output-logger": "6.4.5",
    "@sinclair/typebox": "0.34.41",
    "ulidx": "2.4.1"
  },
  "devDependencies": {
    "@aws-cdk/toolkit-lib": "1.10.0",
    "@aws-sdk/client-cloudfront": "3.908.0",
    "@aws-sdk/client-cloudwatch-logs": "3.908.0",
    "@aws-sdk/client-cognito-identity-provider": "3.908.0",
    "@aws-sdk/client-dynamodb": "3.908.0",
    "@aws-sdk/client-s3": "3.908.0",
    "@aws-sdk/client-ses": "3.908.0",
    "@aws-sdk/client-sts": "3.908.0",
    "@aws-sdk/util-dynamodb": "3.908.0",
    "@babel/plugin-syntax-import-assertions": "7.27.1",
    "@bifravst/aws-cdk-lambda-helpers": "3.5.54",
    "@bifravst/bdd-markdown": "8.2.78",
    "@bifravst/ci": "2.1.1",
    "@bifravst/cloudformation-helpers": "9.1.1",
    "@bifravst/eslint-config-typescript": "6.4.4",
    "@bifravst/prettier-config": "1.1.13",
    "@commitlint/config-conventional": "19.8.1",
    "@hello.nrfcloud.com/bdd-markdown-steps": "3.1.35",
    "@types/aws-lambda": "8.10.155",
    "@types/command-line-args": "5.2.3",
    "@types/node": "24.7.1",
    "aws-cdk-lib": "2.219.0",
    "check-node-version": "4.2.1",
    "command-line-args": "6.0.1",
    "commitlint": "19.8.1",
    "husky": "9.1.7",
    "lint-staged": "16.2.3",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint"
    ],
    "*.{md,json,yaml,yml,html,css}": [
      "prettier --write"
    ]
  },
  "prettier": "@bifravst/prettier-config",
  "release": {
    "branches": [
      "saga"
    ],
    "remoteTags": true,
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      [
        "@semantic-release/github",
        {
          "successCommentCondition": false,
          "failTitle": false
        }
      ]
    ]
  }
}
